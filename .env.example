# PolicyStack Environment Template
# Duplicate this to .env and fill in required values.

# =============================================================================
# Core Paths
# =============================================================================

# Root directory of the policy repository (default: auto-detected)
POLICY_REPO_ROOT=

# Path to the audit log file (default: ~/.policy-federation/audit.jsonl)
POLICY_AUDIT_LOG_PATH=

# Path for streaming audit events (optional, enables real-time audit)
POLICY_AUDIT_STREAM=

# =============================================================================
# Policy Resolution
# =============================================================================

# Repo name used in policy resolution (default: inferred from cwd)
POLICY_REPO=

# Harness name for delegation (e.g., claude, codex, cursor, factory-droid)
POLICY_DELEGATE_HARNESS=claude

# Task domain scope (e.g., devops, query, analysis)
POLICY_TASK_DOMAIN=devops

# Task-instance override file path
POLICY_TASK_INSTANCE=

# Task-level overlay file path
POLICY_TASK_OVERLAY=

# =============================================================================
# Review / Ask Mode
# =============================================================================

# Policy mode: audit, allow, deny, ask
POLICY_MODE=ask

# Ask mode: review, auto, skip
POLICY_ASK_MODE=review

# Override the reviewer binary path
POLICY_REVIEW_BIN=

# Model used by the reviewer (e.g., claude-sonnet-4-20250514)
POLICY_REVIEW_MODEL=

# =============================================================================
# Actor / Context
# =============================================================================

# Current actor (user or agent identifier) for audit logging
POLICY_ACTOR=

# =============================================================================
# Integrations
# =============================================================================

# ForgeCode API key (required if using forge integration)
FORGECODE_API_KEY=
