{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Policy Contract",
  "type": "object",
  "required": ["version", "id", "scope", "policy"],
  "properties": {
    "version": {"type": "string"},
    "id": {"type": "string"},
    "scope": {"type": "string"},
    "extends": {"type": "array", "items": {"type": "string"}},
    "merge": {
      "type": "object",
      "required": ["strategy"],
      "properties": {
        "strategy": {"enum": ["replace", "append", "append_unique", "merge_map"]}
      }
    },
    "policy": {
      "type": "object",
      "properties": {
        "authorization": {
          "type": "object",
          "properties": {
            "defaults": {
              "type": "object",
              "additionalProperties": {
                "enum": ["allow", "deny", "ask"]
              }
            },
            "rules": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id", "effect", "actions"],
                "properties": {
                  "id": {"type": "string"},
                  "description": {"type": "string"},
                  "priority": {"type": "integer"},
                  "effect": {"enum": ["allow", "deny", "ask"]},
                  "actions": {
                    "type": "array",
                    "minItems": 1,
                    "items": {"type": "string"}
                  },
                  "match": {
                    "type": "object",
                    "properties": {
                      "command_patterns": {
                        "type": "array",
                        "items": {"type": "string"}
                      },
                      "cwd_patterns": {
                        "type": "array",
                        "items": {"type": "string"}
                      },
                      "actor_patterns": {
                        "type": "array",
                        "items": {"type": "string"}
                      },
                      "target_path_patterns": {
                        "type": "array",
                        "items": {"type": "string"}
                      },
                      "exclude_patterns": {
                        "type": "array",
                        "items": {"type": "string"}
                      }
                    },
                    "additionalProperties": false
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  }
}
